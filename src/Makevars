# Makevars — built for R CMD INSTALL. The Torch backend is opt-in via
# FSGEA_TORCH=1 and FSGEA_TORCH_HOME pointing at an unpacked LibTorch
# distribution. Without those, the package still builds CPU-only.

CXX_STD = CXX20

PKG_CPPFLAGS = -I.
PKG_CXXFLAGS = -O3 -Wall -Wextra -Wpedantic -fvisibility=hidden

# Link the threading library for std::execution::par_unseq. On Linux this
# additionally pulls in TBB which std::execution::par_unseq requires; users
# without TBB will fall back to sequential execution silently (libstdc++)
# or get a link error (libc++). Override TBB_LIBS to "" to disable.
PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS) -lpthread
TBB_LIBS ?= -ltbb
PKG_LIBS += $(TBB_LIBS)

ifeq ($(FSGEA_TORCH),1)
  ifndef FSGEA_TORCH_HOME
    $(error FSGEA_TORCH=1 requires FSGEA_TORCH_HOME to point at a LibTorch install)
  endif
  PKG_CPPFLAGS += -DFSGEA_WITH_TORCH \
                  -I$(FSGEA_TORCH_HOME)/include \
                  -I$(FSGEA_TORCH_HOME)/include/torch/csrc/api/include
  PKG_LIBS += -L$(FSGEA_TORCH_HOME)/lib \
              -Wl,-rpath,$(FSGEA_TORCH_HOME)/lib \
              -ltorch -ltorch_cpu -lc10
  ifeq ($(FSGEA_TORCH_CUDA),1)
    PKG_LIBS += -ltorch_cuda -lc10_cuda
  endif
endif
