# Makevars — POSIX build (Linux, macOS).
#
# TBB powers std::execution::par_unseq under libstdc++. We detect it first
# via pkg-config (works on every Linux distro and macOS-with-Homebrew that
# has pkg-config on PATH), then fall back to Homebrew's prefix on macOS,
# then to a bare `-ltbb` on the assumption that the linker can find it.
#
# The optional Torch backend is enabled by setting FSGEA_TORCH=1 and
# pointing FSGEA_TORCH_HOME at an unpacked LibTorch distribution.

CXX_STD = CXX20

# R provides its own optimization flags via Makeconf — don't override here;
# CRAN forbids hard-coded -O3, -march=native, etc. in PKG_CXXFLAGS.
PKG_CPPFLAGS = -I.

# Threading
PKG_LIBS = -lpthread

# --- TBB detection ---------------------------------------------------------
TBB_VIA_PKG_CONFIG := $(shell pkg-config --exists tbb && echo 1)
ifeq ($(TBB_VIA_PKG_CONFIG),1)
  PKG_CPPFLAGS += $(shell pkg-config --cflags tbb)
  PKG_LIBS    += $(shell pkg-config --libs tbb)
else
  UNAME_S := $(shell uname -s)
  ifeq ($(UNAME_S),Darwin)
    BREW_TBB := $(shell brew --prefix tbb 2>/dev/null)
    ifneq ($(BREW_TBB),)
      PKG_CPPFLAGS += -I$(BREW_TBB)/include
      PKG_LIBS    += -L$(BREW_TBB)/lib -ltbb
    else
      PKG_LIBS    += -ltbb
    endif
  else
    PKG_LIBS += -ltbb
  endif
endif

# --- Optional LibTorch backend --------------------------------------------
ifeq ($(FSGEA_TORCH),1)
  ifndef FSGEA_TORCH_HOME
    $(error FSGEA_TORCH=1 requires FSGEA_TORCH_HOME to point at a LibTorch install)
  endif
  PKG_CPPFLAGS += -DFSGEA_WITH_TORCH \
                  -I$(FSGEA_TORCH_HOME)/include \
                  -I$(FSGEA_TORCH_HOME)/include/torch/csrc/api/include
  PKG_LIBS += -L$(FSGEA_TORCH_HOME)/lib \
              -Wl,-rpath,$(FSGEA_TORCH_HOME)/lib \
              -ltorch -ltorch_cpu -lc10
  ifeq ($(FSGEA_TORCH_CUDA),1)
    PKG_LIBS += -ltorch_cuda -lc10_cuda
  endif
endif
