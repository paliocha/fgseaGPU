# Makevars — POSIX build (Linux, macOS).
#
# Parallel std::execution requires Intel TBB at link time on libstdc++.
# Apple libc++ doesn't ship parallel std::execution at all (par_unseq /
# seq policy overloads of the algorithms simply aren't there), so even
# with Homebrew TBB present we must NOT define FSGEA_PARALLEL on macOS
# — the package would otherwise fail to compile against the system
# libc++ headers. Linux gcc/clang against libstdc++ does support the
# parallel policies when libtbb is linked.
#
# We detect TBB via pkg-config (works on most Linux distros). If that
# fails we accept the sequential fallback. `FSGEA_PARALLEL` is only
# defined when TBB is actually wired in; without it the package
# compiles cleanly and uses `std::execution::seq` (see fsgea_exec.hpp).
#
# The optional LibTorch backend is enabled by setting FSGEA_TORCH=1 and
# pointing FSGEA_TORCH_HOME at an unpacked LibTorch distribution.

CXX_STD = CXX20

PKG_CPPFLAGS = -I.

# Threading
PKG_LIBS = -lpthread

# --- TBB detection ---------------------------------------------------------
# Only enable FSGEA_PARALLEL on non-Darwin hosts. Apple libc++ doesn't
# ship parallel std::execution, so even Homebrew TBB can't unlock par_unseq
# there — turning it on would just break compilation.
UNAME_S := $(shell uname -s)
ifneq ($(UNAME_S),Darwin)
  TBB_VIA_PKG_CONFIG := $(shell pkg-config --exists tbb && echo 1)
  ifeq ($(TBB_VIA_PKG_CONFIG),1)
    PKG_CPPFLAGS += $(shell pkg-config --cflags tbb) -DFSGEA_PARALLEL
    PKG_LIBS    += $(shell pkg-config --libs tbb)
  endif
endif

# --- Optional Neumaier compensated accumulation ---------------------------
# Set FSGEA_PRECISE=1 to enable opt-in Neumaier-compensated summation in
# calcEs's running-sum walk. Costs two extra fp adds per member; pays off
# only when ES values cluster near zero in very large pathways or when
# accumulating across 10^6+ permutations. The default is off.
ifeq ($(FSGEA_PRECISE),1)
  PKG_CPPFLAGS += -DFSGEA_PRECISE_ACCUM
endif

# --- Optional LibTorch backend --------------------------------------------
ifeq ($(FSGEA_TORCH),1)
  ifndef FSGEA_TORCH_HOME
    $(error FSGEA_TORCH=1 requires FSGEA_TORCH_HOME to point at a LibTorch install)
  endif
  PKG_CPPFLAGS += -DFSGEA_WITH_TORCH \
                  -I$(FSGEA_TORCH_HOME)/include \
                  -I$(FSGEA_TORCH_HOME)/include/torch/csrc/api/include
  PKG_LIBS += -L$(FSGEA_TORCH_HOME)/lib \
              -Wl,-rpath,$(FSGEA_TORCH_HOME)/lib \
              -ltorch -ltorch_cpu -lc10
  ifeq ($(FSGEA_TORCH_CUDA),1)
    PKG_LIBS += -ltorch_cuda -lc10_cuda
  endif
endif
